# Copy this file to .env and fill in real values. Never commit .env.

# Postgres connection string used by Prisma
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/capabl?schema=public"

# JWT signing secret — use a long random string in production
JWT_SECRET="change_me_to_a_long_random_string"

# Backend port
PORT=5000

# Public app URLs used for OAuth redirects and uploaded asset links
BACKEND_URL="http://localhost:5000"
FRONTEND_URL="http://localhost:3000"

# Optional GitHub token to avoid anonymous API rate limits when syncing repos
GITHUB_TOKEN="your_personal_access_token"

# Google OAuth login
GOOGLE_CLIENT_ID="your_google_client_id"
GOOGLE_CLIENT_SECRET="your_google_client_secret"
# Optional override. Defaults to BACKEND_URL + /api/auth/google/callback
GOOGLE_CALLBACK_URL="http://localhost:5000/api/auth/google/callback"

# Gemini AI analysis and interview generation
GEMINI_API_KEY="your_gemini_api_key"
# Optional legacy alias also supported by job match
GOOGLE_GENERATIVE_AI_KEY="your_gemini_api_key"

# Optional Retell voice interview integration
RETELL_API_KEY="your_retell_api_key"
RETELL_AGENT_ID="your_retell_agent_id"
RETELL_PHONE_NUMBER="your_retell_phone_number"
RETELL_AGENT_NAME="Rexa"

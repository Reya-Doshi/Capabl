generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            Int      @id @default(autoincrement())

  name          String
  email         String   @unique
  password      String

  college       String?
  age           Int?
  bio           String?
  github        String?
  linkedin      String?
  resume        String?
  profilePic    String?

  createdAt     DateTime @default(now())

  skills         Skill[]
  roadmaps       Roadmap[]
  achievements   Achievement[]
  aiAnalysis     AIAnalysis?
}

model Skill {
  id        Int    @id @default(autoincrement())
  name      String

  userId    Int
  user      User   @relation(fields: [userId], references: [id])
}

model Roadmap {
  id          Int      @id @default(autoincrement())
  title       String
  progress    Int      @default(0)

  userId      Int
  user        User     @relation(fields: [userId], references: [id])
}

model Achievement {
  id          Int      @id @default(autoincrement())
  title       String

  userId      Int
  user        User     @relation(fields: [userId], references: [id])
}

model AIAnalysis {

  id                 Int      @id @default(autoincrement())

  bio                String?
  phone              String?
  location           String?

  degree             String?
  specialization     String?
  collegeName        String?
  startYear          String?
  endYear            String?

  languages          String?

  readinessScore     String?
  careerFit          String?

  strengths          String?
  missingSkills      String?
  aiSuggestions      String?

  extractedSkills    String?

  userId             Int      @unique
  user               User     @relation(fields: [userId], references: [id])
}